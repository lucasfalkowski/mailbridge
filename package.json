{
    "name": "cloudflare-email-router",
    "version": "1.0.0",
    "type": "module",
    "engines": {
        "node": "24.x"
    },
    "scripts": {
        "dev": "wrangler dev",
        "deploy": "wrangler deploy",
        "check:syntax": "find src -name '*.js' -print0 | xargs -0 -n 1 node --check",
        "test": "node --test tests/*.test.js",
        "verify": "npm run check:syntax && npm test && npm run deploy -- --dry-run"
    },
    "dependencies": {
        "postal-mime": "^2.7.4"
    },
    "devDependencies": {
        "wrangler": "^4.92.0"
    }
}
